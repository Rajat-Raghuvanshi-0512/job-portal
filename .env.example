# Production Environment Variables Example
# Copy this file to .env and fill in your secrets.
# Do NOT commit the actual .env file to your repository!

# Django Settings
DEBUG=False
SECRET_KEY=your-secret-key-here

# Database Configuration (for the db service and backend)
POSTGRES_DB=jobportal_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DB_NAME=jobportal_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432
